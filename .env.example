# ─── Supabase ────────────────────────────────────────────────────────────────
# Local: rode `pnpm db:start` e copie os valores exibidos por `supabase status`.
# NUNCA commitar chaves reais — este arquivo é apenas o template.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
# service_role: uso EXCLUSIVO no backend/worker (bypassa RLS). Jamais no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend (Vite expõe apenas variáveis VITE_*) ───────────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ─── Fila / Worker (Fase 4 — BullMQ) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rastreamento / veículos (Fase 3) ────────────────────────────────────────
# TRACKING_SOURCE=traccar usa o Traccar; qualquer outro valor usa o mock de dev.
TRACKING_SOURCE=mock
TRACCAR_URL=
TRACCAR_TOKEN=

# ─── Credenciais de portais de brokers (Fase 4 — scraping) ───────────────────
# Padrão: BROKER_<NOME>_USER / BROKER_<NOME>_PASS (ou Supabase Vault em produção)
