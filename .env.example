# ─── Supabase ────────────────────────────────────────────────────────────────
# Local: rode `pnpm db:start` e copie os valores exibidos por `supabase status`.
# NUNCA commitar chaves reais — este arquivo é apenas o template.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
# service_role: uso EXCLUSIVO no backend (bypassa RLS). Jamais no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend (Vite expõe apenas variáveis VITE_*) ───────────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ─── Rastreamento / veículos (Fase 3) ────────────────────────────────────────
# TRACKING_SOURCE=traccar usa o Traccar; qualquer outro valor usa o mock de dev.
TRACKING_SOURCE=mock
TRACCAR_URL=
TRACCAR_TOKEN=
