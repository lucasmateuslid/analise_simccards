{
  "name": "analysis-app",
  "private": true,
  "version": "0.1.0",
  "description": "Gestão de consumo de linhas/chips M2M — consolidação multi-broker, custos e candidatas a cancelamento",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "dev": "pnpm -r --parallel dev",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "supabase": "^2.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
